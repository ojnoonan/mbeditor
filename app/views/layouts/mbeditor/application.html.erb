<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mbeditor — <%= Rails.root.basename %></title>

  <!-- ── Fonts and Styles ──────────────────────────────── -->
  <!-- Direct load FontAwesome to bypass 404s on local woff2 files -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
  <%= stylesheet_link_tag "mbeditor/application", media: "all" %>

  <!-- ── Vendor JS (order matters) ─────────────────────── -->
  <script src="https://cdn.jsdelivr.net/npm/react@18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/react-dom@18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/lodash@4.17.21/lodash.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/minisearch@6.1.0/dist/umd/index.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked@10.0.0/marked.min.js"></script>
  <!-- Prettier -->
  <script src="https://cdn.jsdelivr.net/npm/prettier@3.0.3/standalone.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prettier@3.0.3/plugins/babel.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prettier@3.0.3/plugins/estree.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prettier@3.0.3/plugins/html.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prettier@3.0.3/plugins/postcss.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/prettier@3.0.3/plugins/markdown.js"></script>

  <!-- ── Monaco loader ─────────────────────────────────── -->
  <script>var require = { paths: { vs: '/monaco-editor/vs' } };</script>
  <script src="/monaco-editor/vs/loader.js"></script>
</head>
<body data-rails-root="<%= Rails.root.to_s %>">
  <script>
    window.MBEDITOR_BASE_PATH = "<%= request.script_name.to_s.sub(%r{/$}, '') %>";
  </script>

  <div id="mbeditor-root">
    <%= yield %>
  </div>

  <script>
    window.MonacoEnvironment = {
      getWorkerUrl: function(workerId, label) {
        return '/monaco_worker.js';
      }
    };

    // Wait for Monaco to load before initializing application scripts
    require(['vs/editor/editor.main'], function() {
      // Disable Monaco's built-in JS/TS workers — they can't parse JSX and throw false-positive errors
      if (monaco && monaco.languages && monaco.languages.typescript) {
        monaco.languages.typescript.javascriptDefaults.setDiagnosticsOptions({
          noSemanticValidation: true,
          noSyntaxValidation: true
        });
        monaco.languages.typescript.typescriptDefaults.setDiagnosticsOptions({
          noSemanticValidation: true,
          noSyntaxValidation: true
        });
      }

      var appScript = document.createElement('script');
      appScript.src = '<%= asset_path("mbeditor/application.js") %>';
      appScript.onload = function() {
        var root = document.getElementById('mbeditor-root');
        if (window.MbeditorApp && window.ReactDOM) {
          window.ReactDOM.render(React.createElement(window.MbeditorApp), root);
        } else {
          console.error("Failed to mount: MbeditorApp or ReactDOM is undefined.");
        }
      };
      document.body.appendChild(appScript);
    });
  </script>
</body>
</html>
